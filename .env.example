# Database
DATABASE_URL=postgresql+asyncpg://anchor:anchor@localhost:5432/anchor
DATABASE_URL_SYNC=postgresql://anchor:anchor@localhost:5432/anchor

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=anchor

# SMTP (Mailpit in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@anchor.dev

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1

# App
APP_NAME=Anchor
APP_ENV=development
